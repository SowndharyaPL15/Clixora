# -------------------------------------------------------------
# Clixora Backend - Environment Variables (Example)
# -------------------------------------------------------------

# Server Configuration
PORT=5000
NODE_ENV=production

# URLs (Important for CORS and Redirects)
# URL of your deployed frontend (e.g., https://clixora.netlify.app)
FRONTEND_URL=http://localhost:5173
# URL of your deployed backend (e.g., https://clixora-api.onrender.com)
BACKEND_URL=http://localhost:5000

# Database Configuration
# Neon PostgreSQL Connection String
DATABASE_URL=postgres://<user>:<password>@<endpoint>.neon.tech/<dbname>?sslmode=require

# Authentication
# Secret key for JWT generation (Use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_here
# Expiry time for JWT (e.g., 7d, 24h)
JWT_EXPIRES_IN=7d

# Google OAuth (If applicable)
GOOGLE_CLIENT_ID=your_google_client_id_here
