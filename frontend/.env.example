# -------------------------------------------------------------
# Clixora Frontend - Environment Variables (Example)
# -------------------------------------------------------------

# API Base URL - Point this to your Render backend in production
VITE_API_URL=https://your-backend-api.onrender.com/api

# Backend Base URL - Used for redirect links
VITE_BACKEND_URL=https://your-backend-api.onrender.com

# Google OAuth Client ID (If applicable)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
